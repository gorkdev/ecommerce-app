# ============================================================
# Copy this file to ".env" and adjust the values for your setup.
# ============================================================

# ===== PostgreSQL =====
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_secret
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432

# Connection string used by Prisma (the API service).
DATABASE_URL="postgresql://ecommerce:ecommerce_secret@localhost:5432/ecommerce?schema=public"

# ===== API (NestJS) =====
API_PORT=3000
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ===== Stripe (test mode) =====
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ===== MinIO (S3-compatible object storage) =====
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_BUCKET=product-images
MINIO_REGION=us-east-1
# Browser-reachable base for stored object URLs. Defaults to the endpoint above.
# Set this when clients can't reach "localhost" (e.g. Android emulator -> http://10.0.2.2:9000).
# MINIO_PUBLIC_URL=http://localhost:9000

# ===== Admin (Next.js) =====
ADMIN_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
