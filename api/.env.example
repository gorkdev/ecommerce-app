# API runtime configuration. Copy to ".env" inside the api/ folder.

DATABASE_URL="postgresql://ecommerce:ecommerce_secret@localhost:5432/ecommerce?schema=public"

API_PORT=3000

# Comma-separated list of browser origins allowed to call the API (CORS).
# The admin dashboard dev server runs on :3001 by default.
CORS_ORIGIN=http://localhost:3001

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Path to a Firebase service-account key file (JSON) for FCM push
# notifications. Optional: leave unset to run without push. The key file is
# a secret — keep it out of git (see .gitignore).
# FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=product-images
